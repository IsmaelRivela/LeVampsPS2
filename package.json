{
  "name": "levamps-portfolio",
  "productName": "LeVamps Portfolio",
  "version": "1.0.0",
  "description": "Portfolio retro PS2 — experiencia interactiva",
  "main": "electron/main.js",
  "author": "Ismael Rivela",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac zip",
    "build:win": "electron-builder --win portable",
    "build": "electron-builder --mac zip --win portable"
  },
  "build": {
    "appId": "com.levamps.portfolio",
    "productName": "LeVamps Portfolio",
    "copyright": "Copyright © Ismael Rivela",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "intro.mp4",
      "pantalla2.mp4",
      "assets/**/*",
      "build/icon.png",
      "electron/main.js",
      "electron/preload.js"
    ],
    "asar": true,
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "artifactName": "LeVamps-Portfolio-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "LeVamps-Portfolio-win.${ext}"
    },
    "portable": {
      "artifactName": "LeVamps-Portfolio-win.exe"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
